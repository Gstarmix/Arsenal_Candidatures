{
  "manifest_version": 3,
  "name": "Arsenal Candidatures — Capture d'offres",
  "version": "0.1.0",
  "description": "Capture la page d'offre d'emploi que tu consultes et l'exporte en JSON pour le projet Arsenal_Candidatures.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capturer cette offre d'emploi",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
